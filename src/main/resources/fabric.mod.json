{
	"schemaVersion": 1,
	"id": "rainstalker",
	"version": "${version}",
	"name": "RainStalker",
	"description": "Adds a mob that appears when it rains and stalks players!",
	"authors": [
		"rakstern"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/rainstalker/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.github.rakstern.RainStalker"
		],
		"client": [
			"com.github.rakstern.RainStalkerClient"
		]
	},
	"mixins": [
		"rainstalker.mixins.json",
		{
			"config": "rainstalker.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.2",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}